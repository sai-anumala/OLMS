# Backend Environment Variables
# Copy this file to .env and update values as needed

# Server Configuration
# Port to run the server on (Required)
# Default: 8008
PORT=8008

# Database Configuration (Required)
# MongoDB connection string
# Local: mongodb://localhost:27017/librarydb
# Atlas/Cloud: mongodb+srv://username:password@cluster.mongodb.net/dbname
DB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>

# JWT Secret (Required)
# A strong random string for signing JWT tokens
# Generate with: openssl rand -base64 32
SECRET=your_jwt_secret_key_here_minimum_32_chars

# Optional: Node environment
# NODE_ENV=development

# Optional: CORS origins (comma-separated for multiple origins)
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.com

# Optional: Logging level
# LOG_LEVEL=info

# Optional: Email configuration (if implementing email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Optional: Payment gateway keys
# STRIPE_SECRET_KEY=sk_test_xxx
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=your_secret

# Optional: File upload configuration
# UPLOAD_MAX_SIZE=5000000
# UPLOAD_PATH=./uploads
