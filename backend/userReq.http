Content-Type: application/json

{
  "bookId": "6900aca458ec212ff7e3b45b"
}

### borrow book
PUT http://localhost:8008/user-api/user-borrow
Content-Type: application/json

{
  "bookId":"6900aca458ec212ff7e3b45b"
}

### return book

PUT http://localhost:8008/user-api/return-book
Content-Type: application/json

{
  "bookId":"6900aca458ec212ff7e3b45b"
}

### Borrow Cart Books
PUT http://localhost:8008/user-api/borrow-cart-books
Content-Type: application/json

{
  "books":["6900aca458ec212ff7e3b45c","6900aca458ec212ff7e3b460"]
}

### payment
