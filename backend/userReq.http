Content-Type: application/json

{
  "username":"sairam",
  "password":"12345678"
}
### log out
GET http://localhost:8008/user-api/user-logout

### read all the books
GET http://localhost:8008/book-api/books


###delete book 
DELETE http://localhost:8008/book-api/book/6900aca458ec212ff7e3b45b

### add new book
POST http://localhost:8008/book-api/book
Content-Type: application/json
 
{
  "title": "The Great Gatsby",
  "genre": "Classic",
  "author": "F. Scott Fitzgerald",
  "description": "A novel set in the Jazz Age...",
  "copies": 10,
  "availability": 7,
  "isbn": "97807432s73565",
  "image": "https://example.com/gatsby.jpg",
  "pages": 180,
  "published": "1925-04-10",
  "rating": 4.5
}

###update book
PUT http://localhost:8008/book-api/book
Content-Type: application/json
 
{
  "_id":"6901bd99bbd4bcb8d8fbb896",
  "copies": 40,
  "availability": 0
}

### read all users details 
GET http://localhost:8008/user-api/users


### update user data
