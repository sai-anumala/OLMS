Content-Type: application/json

{
    "_id":"6901dde6ad8cef068ba55ae0",
    "username":"suresh",
    "mobile":98765432234,
    "email":"sureee@gmail.com"
}

### delete user
PUT http://localhost:8008/admin-api/block-user
Content-Type: application/json

{
    "userId":"6901dde6ad8cef068ba55ae0"
}

### add book id to cart
PUT http://localhost:8008/user-api/user-cart/69009fef042c093476a0674c
Content-Type: application/json

{
  "bookId": "69bf93e1a34af32e2ee8d013"
}

### delete book id to cart
